# ──────────────────────────────────────────────────────────────────────────────
# .env.local 생성을 위한 템플릿
#
# 복사 방법:
#   cp .env.example .env.local
# 이후 .env.local에 실제 값 작성
# ──────────────────────────────────────────────────────────────────────────────

# ─── GitHub OAuth App ─────────────────────────────────────────────────────────
# 발급: https://github.com/settings/developers → New OAuth App
# Homepage URL        : http://localhost:3000
# Callback URL        : http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Neon PostgreSQL ──────────────────────────────────────────────────────────
# 발급: https://console.neon.tech → 프로젝트 선택 → Connection string 복사
DATABASE_URL=

# ─── NextAuth.js ──────────────────────────────────────────────────────────────
# JWT 세션 서명에 사용하는 비밀 키. 누출 시 세션 위조가 가능하므로 안전하게 보관
# 생성 방법: openssl rand -base64 32
AUTH_SECRET=

# ─── SEO / canonical URL ──────────────────────────────────────────────────────
# sitemap, canonical, Open Graph URL 생성 기준 도메인
NEXT_PUBLIC_SITE_URL=https://openissuemap.com
